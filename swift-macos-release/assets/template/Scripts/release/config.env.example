# Copy this file to Scripts/release/config.env and customize for local runs.

APP_NAME=__APP_NAME__
XCODE_SCHEME=__XCODE_SCHEME__
XCODE_PROJECT=__XCODE_PROJECT__
XCODE_CONFIGURATION=Release

# preview or production
RELEASE_MODE=preview
APPCAST_FILENAME=appcast-preview.xml

# Feed users see in-app (SUFeedURL)
SPARKLE_FEED_URL=https://github.com/__GITHUB_REPO_SLUG__/releases/latest/download/appcast-preview.xml

# Where generate_appcast points enclosure URLs for release archives
# For GitHub Actions tags this can be inferred automatically.
SPARKLE_DOWNLOAD_URL_PREFIX=

# Optional release notes URL prefix and channel (eg beta)
SPARKLE_RELEASE_NOTES_URL_PREFIX=
SPARKLE_CHANNEL=

# Sparkle keys
# Public key is safe to expose. Private key must stay in secrets.
SPARKLE_PUBLIC_KEY=
SPARKLE_PRIVATE_KEY=

# Production notarization vars (not used in preview mode)
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# Optional output override directories
# RELEASE_DIR=build/release
# DIST_DIR=build/release/dist
